{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A lighting product available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "formattedPrice": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "isActive": { "type": "boolean" },
        "specs": {
          "type": "object",
          "properties": {
            "material": { "type": "string" },
            "size": { "type": "string" },
            "lighting": { "type": "string" }
          }
        },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "price", "image", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "building": { "type": "string" },
        "city": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "number" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["firstName", "lastName", "email", "phone", "address", "city", "paymentMethod", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available in the store."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    }
  }
}

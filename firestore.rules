rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidOrder(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email', 'phone', 'address', 'city', 'paymentMethod', 'total', 'status', 'createdAt', 'items']) &&
        data.firstName is string && data.firstName.size() <= 100 &&
        data.lastName is string && data.lastName.size() <= 100 &&
        data.email is string && data.email.size() <= 100 &&
        data.phone is string && data.phone.size() <= 50 &&
        data.address is string && data.address.size() <= 200 &&
        data.city is string && data.city.size() <= 100 &&
        data.paymentMethod is string && data.paymentMethod.size() <= 50 &&
        data.total is number &&
        data.status is string && data.status.size() <= 50 &&
        data.createdAt is number &&
        data.items is list && data.items.size() <= 50;
    }

    match /products/{productId} {
      allow read: if isValidId(productId);
      allow write: if false; 
      allow list: if true;
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt == request.time.toMillis();
      allow read, update, delete: if false;
    }
  }
}
